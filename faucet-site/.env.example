# Copiez ce fichier en ".env" et remplissez les vraies valeurs. Ne JAMAIS commit le .env réel.

# Secret pour signer les sessions - générez une longue chaîne aléatoire
SESSION_SECRET=changez_moi_par_une_chaine_aleatoire_longue

# hCaptcha - creez un compte gratuit sur https://www.hcaptcha.com
HCAPTCHA_SITEKEY=votre_site_key
HCAPTCHA_SECRET=votre_secret_key

# FaucetPay - https://faucetpay.io (API dans votre dashboard FaucetPay)
FAUCETPAY_API_KEY=votre_api_key_faucetpay

# Montant distribué par réclamation (en unité interne, ex: satoshis ou points)
CLAIM_AMOUNT=10

# Cooldown entre 2 réclamations, en secondes (3600 = 1 heure)
CLAIM_COOLDOWN_SECONDS=3600

# Port du serveur
PORT=3000
